<?xml version="1.0" encoding="utf-8"?>
<!--
    Adaptive icon — used by Android 8.0+ (API 26+), including Android 10.
    The launcher applies its own shape mask (circle, squircle, rounded square, etc.).
    foreground: the safe/keypad PNG scaled to 108dp viewport
    background: Adyen Black, so any bleed area outside the mask is on-brand
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@drawable/ic_launcher_background" />
    <foreground android:drawable="@drawable/ic_launcher_foreground" />
</adaptive-icon>
