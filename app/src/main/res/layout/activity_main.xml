<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/adyen_black"
    android:padding="24dp">

    <!-- Adyen logo — top-left -->
    <ImageView
        android:id="@+id/ivLogo"
        android:layout_width="wrap_content"
        android:layout_height="28dp"
        android:src="@drawable/ic_adyen_logo"
        android:contentDescription="Adyen"
        android:adjustViewBounds="true"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- App subtitle — top-right, vertically centred with logo -->
    <TextView
        android:id="@+id/tvAppName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textColor="@color/adyen_grey"
        android:textSize="11sp"
        android:letterSpacing="0.06"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/ivLogo"
        app:layout_constraintBottom_toBottomOf="@id/ivLogo" />

    <!-- Prompt label — centred below header -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:text="@string/enter_code"
        android:textColor="@color/adyen_grey"
        android:textSize="15sp"
        android:letterSpacing="0.05"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ivLogo" />

    <!-- PIN dots -->
    <LinearLayout
        android:id="@+id/llPinDots"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTitle">

        <View android:id="@+id/dot1" style="@style/PinDot" />
        <View android:id="@+id/dot2" style="@style/PinDot" />
        <View android:id="@+id/dot3" style="@style/PinDot" />
        <View android:id="@+id/dot4" style="@style/PinDot" />
    </LinearLayout>

    <!-- Status / error message -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center"
        android:minHeight="44dp"
        android:text=""
        android:textColor="@color/accent_red"
        android:textSize="13sp"
        android:lineSpacingMultiplier="1.2"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/llPinDots" />

    <!-- Numpad grid -->
    <GridLayout
        android:id="@+id/gridNumpad"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:columnCount="3"
        android:rowCount="4"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvStatus">

        <Button android:id="@+id/btn1"     style="@style/NumKey"          android:text="1" />
        <Button android:id="@+id/btn2"     style="@style/NumKey"          android:text="2" />
        <Button android:id="@+id/btn3"     style="@style/NumKey"          android:text="3" />
        <Button android:id="@+id/btn4"     style="@style/NumKey"          android:text="4" />
        <Button android:id="@+id/btn5"     style="@style/NumKey"          android:text="5" />
        <Button android:id="@+id/btn6"     style="@style/NumKey"          android:text="6" />
        <Button android:id="@+id/btn7"     style="@style/NumKey"          android:text="7" />
        <Button android:id="@+id/btn8"     style="@style/NumKey"          android:text="8" />
        <Button android:id="@+id/btn9"     style="@style/NumKey"          android:text="9" />
        <Button android:id="@+id/btnClear" style="@style/NumKeySecondary" android:text="CLR" />
        <Button android:id="@+id/btn0"     style="@style/NumKey"          android:text="0" />
        <Button android:id="@+id/btnBack"  style="@style/NumKeySecondary" android:text="⌫" />
    </GridLayout>

    <!-- Loading spinner -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginTop="20dp"
        android:indeterminateTint="@color/adyen_green"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/gridNumpad" />

</androidx.constraintlayout.widget.ConstraintLayout>
