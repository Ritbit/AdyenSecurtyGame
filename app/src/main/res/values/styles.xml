<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.CastlesApp" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimary">@color/adyen_green</item>
        <item name="colorPrimaryVariant">@color/key_bg_secondary</item>
        <item name="colorOnPrimary">@color/adyen_white</item>
        <item name="android:windowBackground">@color/adyen_black</item>
        <item name="android:statusBarColor">@color/adyen_black</item>
    </style>

    <!-- Full-screen theme for PrintResultActivity -->
    <style name="Theme.CastlesApp.Fullscreen" parent="Theme.CastlesApp">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>

    <!-- Numeric keypad button -->
    <style name="NumKey">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">60dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:layout_margin">6dp</item>
        <item name="android:backgroundTint">@color/key_bg</item>
        <item name="android:textColor">@color/adyen_white</item>
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <!-- Clear / back button — slightly darker -->
    <style name="NumKeySecondary" parent="NumKey">
        <item name="android:backgroundTint">@color/key_bg_secondary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/adyen_grey</item>
    </style>

    <!-- PIN indicator dot -->
    <style name="PinDot">
        <item name="android:layout_width">18dp</item>
        <item name="android:layout_height">18dp</item>
        <item name="android:layout_margin">10dp</item>
        <item name="android:background">@drawable/dot_empty</item>
    </style>

</resources>
